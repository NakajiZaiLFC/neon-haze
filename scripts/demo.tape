Output demo.gif

Set Shell "bash"
Set FontSize 14
Set Width 900
Set Height 500
Set Padding 20
Set Theme "Dracula"

Type "bash scripts/logo.sh"
Enter
Sleep 3s

Type "# Theme: neon (default)"
Enter
Type "echo 'neon' > ~/.claude/state/current-theme"
Enter
Type@50ms 'echo '"'"'{"workspace":{"current_dir":"/Users/nassy/projects/neon-haze"},"model":{"display_name":"Opus 4.7"},"context_window":{"used_percentage":47},"cost":{"total_cost_usd":24.42}}'"'"' | COLUMNS=90 bash neonhaze.sh'
Enter
Sleep 3s

